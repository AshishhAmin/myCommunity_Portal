generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  firebaseUid        String?             @unique
  email              String              @unique
  password           String
  name               String?
  role               String              @default("member")
  mobile             String?             @unique
  gotra              String?
  location           String?
  bio                String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  status             String              @default("pending")
  profileImage       String?
  achievements       Achievement[]
  businesses         Business[]
  donations          Donation[]
  events             Event[]
  attendedEvents     EventAttendee[]
  following          Follow[]            @relation("UserFollowers")
  followers          Follow[]            @relation("UserFollowing")
  helpRequests       HelpRequest[]
  jobs               Job[]               @relation("UserJobs")
  mentorships        Mentorship[]        @relation("UserMentorships")
  mentorshipRequests MentorshipRequest[]
  reports            Report[]
  supportTickets     SupportTicket[]
  scholarships       Scholarship[]       @relation("UserScholarships")
  likes              Like[]
  comments           Comment[]
  shares             Share[]
}

model Business {
  id          String   @id @default(cuid())
  ownerId     String
  name        String
  description String
  category    String
  address     String?
  city        String?
  contact     String?
  images      String[]
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       User     @relation(fields: [ownerId], references: [id])
}

model Event {
  id               String          @id @default(cuid())
  organizerId      String
  title            String
  description      String
  date             DateTime
  location         String
  images           String[]
  audience         String          @default("public")
  registrationLink String?
  status           String          @default("pending")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  organizer        User            @relation(fields: [organizerId], references: [id])
  attendees        EventAttendee[]
}

model Donation {
  id            String   @id @default(cuid())
  donorId       String?
  amount        Float
  cause         String
  transactionId String?
  status        String   @default("completed")
  createdAt     DateTime @default(now())
  donor         User?    @relation(fields: [donorId], references: [id])
}

model Job {
  id           String    @id @default(cuid())
  posterId     String
  title        String
  company      String
  location     String
  type         String
  salary       String?
  description  String
  contactEmail String?
  contactPhone String?
  deadline     DateTime?
  status       String    @default("pending")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  poster       User      @relation("UserJobs", fields: [posterId], references: [id])
}

model Scholarship {
  id          String   @id @default(cuid())
  posterId    String
  title       String
  amount      String
  type        String   @default("General")
  eligibility String
  description String
  deadline    DateTime
  link        String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  poster      User     @relation("UserScholarships", fields: [posterId], references: [id])
}

model Mentorship {
  id        String              @id @default(cuid())
  mentorId  String
  expertise String
  bio       String
  available Boolean             @default(true)
  status    String              @default("pending")
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  mentor    User                @relation("UserMentorships", fields: [mentorId], references: [id])
  requests  MentorshipRequest[]
}

model MentorshipRequest {
  id           String     @id @default(cuid())
  mentorshipId String
  requesterId  String
  status       String     @default("pending")
  message      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  mentorship   Mentorship @relation(fields: [mentorshipId], references: [id])
  requester    User       @relation(fields: [requesterId], references: [id])

  @@unique([mentorshipId, requesterId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowers", fields: [followerId], references: [id])
  following   User     @relation("UserFollowing", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

model EventAttendee {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String
  date        DateTime
  category    String
  images      String[]
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model HelpRequest {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  description String
  contact     String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model Report {
  id           String   @id @default(cuid())
  reporterId   String
  contentType  String
  contentId    String
  contentTitle String
  posterName   String?
  posterEmail  String?
  reason       String
  details      String?
  status       String   @default("open")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  reporter     User     @relation(fields: [reporterId], references: [id])
}

model SupportTicket {
  id        String   @id @default(cuid())
  userId    String?
  category  String
  subject   String
  body      String
  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])
}

model Announcement {
  id        String   @id @default(cuid())
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Like {
  id          String   @id @default(cuid())
  userId      String
  contentType String   // 'event', 'business', 'achievement'
  contentId   String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentType, contentId])
}

model Comment {
  id          String    @id @default(cuid())
  userId      String
  contentType String    // 'event', 'business', 'achievement'
  contentId   String
  content     String
  parentId    String?
  parent      Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[] @relation("CommentReplies")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Share {
  id          String   @id @default(cuid())
  userId      String?
  contentType String   // 'event', 'business', 'achievement'
  contentId   String
  platform    String?  // 'whatsapp', 'x', 'copy'
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}
